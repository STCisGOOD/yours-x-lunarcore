<?xml version="1.0" encoding="utf-8"?>
<!--
    USB Device Filter for LoRa Companion Devices

    Matches common ESP32 USB-to-serial chips used in LoRa development boards:
    - CP210x (Silicon Labs) - Used in many ESP32 DevKits
    - CH340 (WCH) - Common in budget ESP32 boards
    - FTDI - Used in some development boards
    - ESP32-S2/S3 native USB
    - Heltec WiFi LoRa 32 V3 (ESP32-S3 with CP2102N)
    - LilyGo T-Beam (CH9102)
-->
<resources>
    <!-- Silicon Labs CP210x (CP2102, CP2104, CP2102N) -->
    <usb-device vendor-id="4292" product-id="60000" />  <!-- 0x10C4 / 0xEA60 -->
    <usb-device vendor-id="4292" product-id="60016" />  <!-- 0x10C4 / 0xEA70 CP2105 -->

    <!-- WCH CH340/CH341 -->
    <usb-device vendor-id="6790" product-id="29987" />  <!-- 0x1A86 / 0x7523 -->
    <usb-device vendor-id="6790" product-id="21795" />  <!-- 0x1A86 / 0x5523 CH341 -->

    <!-- WCH CH9102 (used in newer boards) -->
    <usb-device vendor-id="6790" product-id="21972" />  <!-- 0x1A86 / 0x55D4 -->

    <!-- FTDI FT232/FT2232 -->
    <usb-device vendor-id="1027" product-id="24577" />  <!-- 0x0403 / 0x6001 FT232 -->
    <usb-device vendor-id="1027" product-id="24592" />  <!-- 0x0403 / 0x6010 FT2232 -->
    <usb-device vendor-id="1027" product-id="24593" />  <!-- 0x0403 / 0x6011 FT4232 -->

    <!-- Espressif ESP32-S2/S3 Native USB CDC -->
    <usb-device vendor-id="12346" product-id="32818" />  <!-- 0x303A / 0x8032 ESP32-S2 -->
    <usb-device vendor-id="12346" product-id="4098" />   <!-- 0x303A / 0x1002 ESP32-S3 -->

    <!-- Prolific PL2303 (some budget boards) -->
    <usb-device vendor-id="1659" product-id="8963" />   <!-- 0x067B / 0x2303 -->
</resources>
